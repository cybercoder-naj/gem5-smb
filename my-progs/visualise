#!/usr/bin/env bash

set -e

: "${1:?Missing executable name}"

pwd=`dirname $0`
filename=`basename $1`

scons build/X86/gem5.opt --ignore-style -j20

echo -en "Compiling $filename.s..."
gcc -nostdlib -no-pie $pwd/$filename.s -o $pwd/$filename
echo "Done."

echo -en "Object dump of $filename..."
objdump -d $pwd/$filename > $pwd/$filename.dump
echo "Done."

./build/X86/gem5.opt \
  --debug-flags=O3PipeView,O3CPUAll \
  --debug-file=../$pwd/$filename-trace.out \
  configs/deprecated/example/se.py \
  --cpu-type=O3CPU \
  --caches \
  --cmd=$pwd/$filename